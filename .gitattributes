# Enforce LF line endings for all text files across platforms.
# Biome expects LF; without this, Windows checkouts (core.autocrlf=true) get CRLF
# and `biome check` / `pnpm lint` fail locally even though CI (Linux) passes.
* text=auto eol=lf

# Binary assets — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
*.pdf  binary
