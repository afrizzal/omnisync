{
  "name": "@omnisync/api",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/helmet": "13.0.2",
    "@fastify/sensible": "6.0.4",
    "@omnisync/config": "workspace:*",
    "@omnisync/db": "workspace:*",
    "@omnisync/queue": "workspace:*",
    "@omnisync/types": "workspace:*",
    "fastify": "5.8.5",
    "fastify-raw-body": "5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "tsx": "^4.0.0",
    "vitest": "4.1.8"
  }
}
