{
  "name": "omnisync",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dev": "turbo run dev",
    "assert:redis": "tsx scripts/assert-redis.ts",
    "db:migrate": "pnpm --filter @omnisync/db migrate",
    "db:generate": "pnpm --filter @omnisync/db generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "ioredis": "^5.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
