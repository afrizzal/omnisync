NODE_ENV=development
# Local docker Postgres — pooled + direct both point here in dev.
# Host port 5433 (docker-compose maps 5433→5432) to avoid clashing with a native PostgreSQL on 5432.
DATABASE_URL=postgresql://omnisync:omnisync@localhost:5433/omnisync?schema=public
DIRECT_URL=postgresql://omnisync:omnisync@localhost:5433/omnisync?schema=public
REDIS_URL=redis://localhost:6379
WEBHOOK_SECRET_SHOPEE=replace-with-shopee-hmac-secret
WEBHOOK_SECRET_TOKOPEDIA=replace-with-tokopedia-hmac-secret
WEBHOOK_SECRET_META_ADS=replace-with-meta-ads-hmac-secret
WEBHOOK_SECRET_CRM=replace-with-crm-hmac-secret
